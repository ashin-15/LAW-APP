rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Laws collection — authenticated users can read; authenticated users can create
    match /laws/{lawId} {
      allow read: if request.auth != null;
      // Prevent privilege escalation: new laws must be pending
      allow create: if request.auth != null && request.resource.data.status == 'pending';
      // Only admin can update (approve/reject)
      allow update: if request.auth != null && request.auth.token.email == 'nevilsanish@gmail.com';
    }
  }
}
